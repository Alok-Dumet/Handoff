// refdata service database schema.
// The Vehicle model mirrors @handoff/contracts VehicleSchema (the source of truth).
generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Transmission {
  automatic
  manual
}

enum VehicleClass {
  economy
  compact
  premium
  suv
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

model Vehicle {
  id           String       @id
  make         String
  model        String
  year         Int
  class        VehicleClass
  transmission Transmission
  seats        Int
  pricePerDay  Int
  bookings     Booking[]

  @@map("vehicles")
}

model Booking {
  id            String        @id
  vehicleId     String
  customerName  String
  customerEmail String
  startDate     DateTime
  endDate       DateTime
  status        BookingStatus @default(pending)
  createdAt     DateTime      @default(now())
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@map("bookings")
}
